{
  "name": "@richardmcquiston01/online-catalog-cms",
  "version": "0.1.0",
  "description": "Headless TypeScript CMS engine for managing an online product catalog",
  "license": "Apache-2.0",
  "author": "Richard McQuiston <richard.mcquiston01@gmail.com>",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "keywords": [
    "cms",
    "catalog",
    "headless",
    "typescript",
    "sqlite",
    "postgres",
    "mysql",
    "mongodb",
    "redis",
    "s3"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/RichardMcQuiston01/online-catalog-cms.git"
  },
  "bugs": {
    "url": "https://github.com/RichardMcQuiston01/online-catalog-cms/issues"
  },
  "homepage": "https://github.com/RichardMcQuiston01/online-catalog-cms#readme",
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "prepublishOnly": "bun run typecheck && bun run test && bun run build",
    "demo": "bunx serve demo"
  },
  "optionalDependencies": {
    "@aws-sdk/client-s3": "^3.0.0",
    "better-sqlite3": "^9.0.0",
    "ioredis": "^5.0.0",
    "mongodb": "^6.0.0",
    "mysql2": "^3.0.0",
    "postgres": "^3.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/better-sqlite3": "^7.0.0",
    "@types/node": "^22.0.0",
    "bun-types": "^1.3.14",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "trustedDependencies": [
    "@biomejs/biome"
  ]
}
